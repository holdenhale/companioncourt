{
  "name": "companioncourt",
  "version": "0.2.1",
  "private": false,
  "license": "Apache-2.0",
  "author": "Holden Hale",
  "description": "CompanionCourt — a public docket for pressure-testing AI companions: runner, subject adapter, dual judge families, scoring, run manifests, and CLI.",
  "repository": { "type": "git", "url": "git+https://github.com/holdenhale/companioncourt.git" },
  "homepage": "https://companioncourt.ai",
  "keywords": ["ai-companions", "llm-evaluation", "evaluation-harness", "transcripts", "public-docket"],
  "type": "module",
  "bin": { "companioncourt": "dist/bin/cli.js" },
  "files": ["dist", "src", "CHANGELOG.md", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "bench:smoke": "node dist/bin/cli.js smoke",
    "bench:anchor": "node dist/bin/cli.js anchor",
    "bench:run": "node dist/bin/cli.js run",
    "bench:docket": "node dist/bin/cli.js docket",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.8.3"
  },
  "engines": { "node": ">=23.7.0" }
}
